# ─────────────────────────────────────────────────────────────────────────────
# C1ProspectingBot v2 — Environment Variables
# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Slack (Socket Mode) ──────────────────────────────────────────────────────
# Bot token — xoxb-... — requires app_mentions:read, chat:write scopes
SLACK_BOT_TOKEN=xoxb-

# App-level token — xapp-... — requires connections:write scope
SLACK_APP_TOKEN=xapp-

# Channel to post scheduled morning kickoff into
SLACK_CHANNEL=ai-prospecting

# ── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-

# ── Salesforce REST API ──────────────────────────────────────────────────────
# Instance URL: e.g. https://yourorg.my.salesforce.com
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
# OAuth 2.0 access token — Connected App recommended for prod
SF_ACCESS_TOKEN=

# ── Common Room ──────────────────────────────────────────────────────────────
# Primary intent signal source — get key from Common Room settings
COMMONROOM_API_KEY=
# Optional: restrict to a specific community ID (found in Common Room URL)
COMMONROOM_COMMUNITY_ID=

# ── Lusha ────────────────────────────────────────────────────────────────────
# Contact enrichment (email, phone) + company firmographics
LUSHA_API_KEY=

# ── Apollo.io ────────────────────────────────────────────────────────────────
# Contact enrichment — broader coverage than Lusha, reveals personal emails
APOLLO_API_KEY=

# ── Google Drive (OAuth2) ────────────────────────────────────────────────────
# One-time browser sign-in via 'auth google' command in CLI mode.
# Setup: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
#   - Application type: Desktop app
#   - Redirect URI: http://localhost:9999/callback
#   - Enable: Google Drive API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=   # auto-populated after 'auth google'

# Collateral folder ID — scopes all Drive searches to this folder and subfolders
# https://drive.google.com/drive/folders/12ouswmhsYcbj_pfVAg81E6_udcy7SkDG
GOOGLE_DRIVE_FOLDER_ID=12ouswmhsYcbj_pfVAg81E6_udcy7SkDG

# ── Gong ─────────────────────────────────────────────────────────────────────
GONG_ACCESS_KEY=
GONG_ACCESS_KEY_SECRET=

# ── Notion ───────────────────────────────────────────────────────────────────
# Integration token — create at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_

# ── Brave Search ─────────────────────────────────────────────────────────────
# Web search for employee count verification + buying signal research
# Get key at: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=

# ── Scheduler ────────────────────────────────────────────────────────────────
# Cron expression for morning kickoff (default: 6am PT Mon–Fri)
# Set to "* * * * *" to fire every minute for testing
SCHEDULE_CRON=0 6 * * 1-5
TZ=America/Los_Angeles
